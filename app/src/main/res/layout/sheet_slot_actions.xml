<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/sheet_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="8dp"
        android:textAppearance="?attr/textAppearanceSubtitle1"
        android:textStyle="bold"
        tools:text="Source"
        xmlns:tools="http://schemas.android.com/tools" />

    <TextView
        android:id="@+id/action_pick_files"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:drawableStart="@android:drawable/ic_menu_gallery"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/slot_action_pick_files"
        android:textAppearance="?attr/textAppearanceBody1" />

    <TextView
        android:id="@+id/action_pick_folder"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:drawableStart="@android:drawable/ic_menu_more"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/slot_action_pick_folder"
        android:textAppearance="?attr/textAppearanceBody1" />

    <TextView
        android:id="@+id/action_clear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:drawableStart="@android:drawable/ic_menu_close_clear_cancel"
        android:drawablePadding="16dp"
        android:gravity="center_vertical"
        android:minHeight="56dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:text="@string/slot_action_clear"
        android:textAppearance="?attr/textAppearanceBody1"
        android:textColor="@color/status_error" />

</LinearLayout>
