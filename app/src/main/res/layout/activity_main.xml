<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/AppTheme.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:title="@string/app_name" />

        <TextView
            android:id="@+id/status_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:background="@color/status_idle"
            tools:text="Ready to run." />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="12dp"
            android:paddingBottom="96dp">

            <!-- Command card: preset chips + (when Custom selected) editor + slot toolbar -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AppTheme.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppTheme.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_command" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/preset_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        app:chipSpacingHorizontal="4dp"
                        app:chipSpacingVertical="2dp"
                        app:singleSelection="true"
                        app:selectionRequired="true" />

                    <TextView
                        android:id="@+id/preset_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?android:textColorSecondary"
                        tools:text="Read every tag from the picked files and print them." />

                    <!-- Custom command editor — visible only when Custom preset selected -->
                    <LinearLayout
                        android:id="@+id/custom_command_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <HorizontalScrollView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:scrollbars="none">

                                <LinearLayout
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/insert_source_button"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="6dp"
                                        android:minHeight="36dp"
                                        android:text="@string/custom_toolbar_source"
                                        android:textSize="12sp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/insert_target_button"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="6dp"
                                        android:minHeight="36dp"
                                        android:text="@string/custom_toolbar_target"
                                        android:textSize="12sp" />

                                    <com.google.android.material.button.MaterialButton
                                        android:id="@+id/insert_sidecar_button"
                                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:minHeight="36dp"
                                        android:text="@string/custom_toolbar_sidecar"
                                        android:textSize="12sp" />

                                </LinearLayout>
                            </HorizontalScrollView>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/save_preset_button"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="6dp"
                                android:minHeight="36dp"
                                android:text="@string/custom_toolbar_save"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:hint="@string/custom_command_hint"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                            <me.bestvibes.exiftoolwrapper.SlotEditText
                                android:id="@+id/custom_command_edit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="text|textMultiLine|textNoSuggestions"
                                android:textSize="13sp"
                                android:fontFamily="monospace"
                                android:imeOptions="actionDone" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:id="@+id/custom_command_error"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="@color/status_error"
                            android:textAppearance="?attr/textAppearanceCaption"
                            android:visibility="gone"
                            tools:visibility="visible"
                            tools:text="Unknown slot type: {foo}." />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Files / slots card: one slot chip per declared slot -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AppTheme.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppTheme.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_files" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/slot_chip_group"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp" />

                    <TextView
                        android:id="@+id/footer_warning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textAppearance="?attr/textAppearanceCaption"
                        android:textColor="?android:textColorSecondary"
                        tools:text="Files written: this will modify your originals." />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Preview card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AppTheme.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppTheme.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_preview" />

                    <TextView
                        android:id="@+id/preview_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:padding="10dp"
                        android:background="@color/preview_background"
                        android:fontFamily="monospace"
                        android:textIsSelectable="true"
                        android:textSize="12sp"
                        tools:text="exiftool -tagsFromFile «Source» -all:all -overwrite_original «Files»" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Output card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/AppTheme.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/AppTheme.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/section_output" />

                    <me.bestvibes.exiftoolwrapper.MaxHeightNestedScrollView
                        android:id="@+id/output_text_scrollview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:maxHeight="240dp"
                        android:layout_marginTop="6dp"
                        android:scrollbars="vertical"
                        android:fillViewport="true">

                        <TextView
                            android:id="@+id/output_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="10dp"
                            android:background="@color/output_background"
                            android:fontFamily="monospace"
                            android:textIsSelectable="true"
                            android:textSize="12sp"
                            android:text="@string/output_empty" />

                    </me.bestvibes.exiftoolwrapper.MaxHeightNestedScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/run_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:text="@string/button_run"
        app:icon="@android:drawable/ic_media_play" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
